{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/app",
      "dest": "/public/app.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "STRIPE_SECRET_KEY": "@stripe_secret",
    "STRIPE_PRICE_PRO": "@stripe_price_pro",
    "STRIPE_PRICE_ENT": "@stripe_price_ent"
  }
}